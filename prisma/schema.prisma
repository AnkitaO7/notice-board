generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id             Int      @id @default(autoincrement())
  title          String
  body           String
  category       String
  priority       String
  priorityWeight Int      @default(1)
  publishDate    DateTime
  createdAt      DateTime @default(now())
}